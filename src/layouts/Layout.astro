---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
}

const { title = "estefania sanchez" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Estefania Sanchez — software engineer building full-stack web applications, contributing to open-source projects, and working with machine learning, AI, and agentic coding tools." />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content="estefania sanchez — software engineer" />
    <meta property="og:description" content="Full-stack developer, open-source contributor, and ML/AI practitioner. From conventional programming to agentic coding with LLMs, from web apps to low-level C++." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="estefania sanchez — software engineer" />
    <meta name="twitter:description" content="Full-stack developer, open-source contributor, and ML/AI practitioner. From conventional programming to agentic coding with LLMs, from web apps to low-level C++." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    <Nav />
    <main>
      <slot />
    </main>
    <footer class="border-t border-border px-6 py-8 text-gray text-sm">
      <div class="max-w-5xl mx-auto flex justify-between items-center">
        <span>&copy; {new Date().getFullYear()} estefania sanchez // all rights reserved</span>
        <span class="text-neon tracking-wider">&lt; / &gt;</span>
      </div>
    </footer>
  <script>
    // Easter egg for anyone who opens DevTools
    console.log(
      "%c> ah, you're looking under the hood? nice.",
      "color: #ff6600; font-family: monospace; font-size: 16px; font-weight: bold;"
    );
    console.log(
      "%c> the source is on github.",
      "color: #ffffff; font-family: monospace; font-size: 14px;"
    );
    console.log(
      "%c> github.com/estefysc/portfolio",
      "color: #888888; font-family: monospace; font-size: 12px;"
    );
    console.log(
      "%c> or just hire me: hello@estefania.me",
      "color: #ff6600; font-family: monospace; font-size: 14px; font-weight: bold;"
    );
  </script>
  </body>
</html>
