---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import ProjectCard from '../components/ProjectCard.astro';
---

<Layout>
  <!-- HERO -->
  <section class="border-b border-border px-6 py-24 md:py-32">
    <div class="max-w-5xl mx-auto">
      <pre class="text-neon text-xs mb-8 hidden md:block">
 ┌─────────────────────────────────────────┐
 │  STATUS: ONLINE                         │
 │  LAST UPDATED: 2026                     │
 └─────────────────────────────────────────┘</pre>
      <p class="text-gray text-sm mb-4">&gt; <span id="typed-intro"></span><span id="typed-cursor" class="text-neon animate-[blink_1s_step-end_infinite]">_</span></p>
      <div id="hero-content" class="hidden">
        <h1 class="text-5xl md:text-7xl font-bold text-light mb-6">
          estefania<span class="text-neon">.</span><span class="text-neon animate-[blink_1s_step-end_infinite]">_</span>
        </h1>
        <p class="text-gray text-lg md:text-xl max-w-2xl mb-8">
          Software engineer building systems, web applications,
          contributing to open source, and exploring machine learning
          and AI. From conventional programming to agentic coding,
          from full-stack web apps to <span class="whitespace-nowrap">low-level C++,</span>
          <br />
          <span class="text-neon">I like understanding how things work under the hood.</span>
        </p>
        <div class="flex gap-4 text-sm">
          <a href="#projects" class="border border-neon text-neon px-4 py-2 hover:bg-neon hover:text-dark uppercase tracking-wider">
            [view work]
          </a>
          <a href="/resume.pdf" download class="border border-border text-light px-4 py-2 hover:bg-light hover:text-dark uppercase tracking-wider">
            [download resume]
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <Section id="about" title="about">
    <div class="grid md:grid-cols-2 gap-8 mb-10">
      <div>
        <p class="text-gray mb-4">
          &gt; Estefania Sanchez is a software engineer based in
          Sarasota, FL. She holds a Bachelor of Applied Science in
          Computing Technology and Software Development from
          <span class="text-light">Valencia College</span>.
          She also studied music composition at
          <span class="text-light">State College of Florida</span>.
        </p>
        <p class="text-gray">
          &gt; Outside of code, she's passionate about
          <span class="text-light">painting</span>,
          <span class="text-light">music</span>, and
          <span class="text-light">soccer</span>.
        </p>
        <p class="text-gray mt-4">
          &gt; Explore the technologies she's worked with in this section.
        </p>
      </div>
      <div>
        {[
          { label: "languages", skills: ["JavaScript", "TypeScript", "Python", "C++", "Rust", "Java", "PHP", "SQL / PL/SQL", "HTML", "CSS", "C#"] },
          { label: "frameworks + tools", skills: ["React", "Node.js", "Flask", "gRPC / Tonic", "Docker", "Git", "Linux", "CI/CD"] },
          { label: "databases", skills: ["PostgreSQL", "Oracle", "SurrealDB", "Vector Databases"] },
          { label: "ml + ai", skills: ["TensorFlow", "PyTorch", "Scikit-learn", "Hugging Face", "AWS Bedrock", "AWS SageMaker"] },
          { label: "agentic coding", skills: ["Claude Code", "Cursor IDE", "ChatGPT", "LangChain", "LangGraph", "RAG", "MCP", "Generative AI"] },
          { label: "cloud + infra", skills: ["AWS (EC2, S3, Lambda)", "DevOps", "Agile"] },
        ].map((category) => (
          <details name="skills" class="mb-4 border border-border hover:border-neon group">
            <summary class="text-neon text-sm px-4 py-3 uppercase tracking-wider cursor-pointer list-none flex items-center justify-between">
              <span>&gt; {category.label}_</span>
              <span class="text-gray group-open:text-neon">[+]</span>
            </summary>
            <div class="grid grid-cols-2 gap-1 text-sm px-4 pb-4">
              {category.skills.map((skill) => (
                <div class="text-gray border-l-2 border-border pl-3 py-1 hover:border-neon hover:text-light">
                  {skill}
                </div>
              ))}
            </div>
          </details>
        ))}

        <details name="skills" class="mb-4 border border-border hover:border-neon group">
          <summary class="text-neon text-sm px-4 py-3 uppercase tracking-wider cursor-pointer list-none flex items-center justify-between">
            <span>&gt; certifications_</span>
            <span class="text-gray group-open:text-neon">[+]</span>
          </summary>
          <div class="text-sm px-4 pb-4 space-y-3">
            {[
              { name: "AWS Certified Machine Learning Engineer Associate", url: "https://aws.amazon.com/verification", id: "f13a9b29a62047629fc35884bf42b9b1" },
              { name: "AWS Certified AI Practitioner", url: "https://aws.amazon.com/verification", id: "177e10883d114d3b96bfdfe777f06c19" },
              { name: "DeepLearning.AI / Stanford ML Specialization", url: "https://www.coursera.org/account/accomplishments/specialization/N8BWHS72QUEZ" },
            ].map((cert) => (
              <div class="border-l-2 border-border pl-3 py-1 hover:border-neon">
                <div class="flex items-start justify-between">
                  <span class="text-gray hover:text-light">{cert.name}</span>
                  <a href={cert.url} target="_blank" rel="noopener noreferrer" class="text-gray hover:bg-neon hover:text-dark px-1 ml-2 shrink-0">
                    [verify]
                  </a>
                </div>
                {cert.id && (
                  <span class="text-xs text-gray">id: {cert.id}</span>
                )}
              </div>
            ))}
          </div>
        </details>
      </div>
    </div>
  </Section>

  <!-- PROJECTS -->
  <Section id="projects" title="projects">
    <div class="grid md:grid-cols-2 gap-4">
      <ProjectCard
        title="ladybird-browser"
        description="Open-source contributor to Ladybird, a web browser building a modern engine from scratch. Implemented web API features (Badging API, Clear-Site-Data, Battery Status API), fixed browser engine bugs affecting CSP compliance, and contributed specification improvements to the WHATWG standards body. Navigated a 100,000+ line C++ codebase."
        tech={["C++", "Web APIs", "Git", "CI/CD"]}
        github="https://github.com/LadybirdBrowser/ladybird"
      />
      <ProjectCard
        title="avored-rust-cms"
        description="Open-source contributor to AvoRed, a headless CMS built in Rust. Implemented a full-stack locale settings feature, developed backend APIs using Rust and gRPC, built type-safe frontend components with React and TypeScript, and designed database schema migrations with SurrealDB."
        tech={["Rust", "gRPC", "React", "TypeScript", "SurrealDB"]}
        github="https://github.com/avored/avored-rust-cms"
      />
      <ProjectCard
        title="lottery-analyzer"
        description="A web application for analyzing lottery data and patterns. Built as a full-stack project exploring data processing and visualization."
        tech={["Python", "Heroku"]}
        link="https://lottery-analyzer.herokuapp.com/"
      />
      <ProjectCard
        title="this-portfolio"
        description="The site you're looking at. Brutalist design, minimal JavaScript, built with Astro and Tailwind CSS, deployed on Cloudflare Pages."
        tech={["Astro", "Tailwind CSS", "Cloudflare Pages"]}
        github="https://github.com/estefysc/portfolio"
      />
    </div>
  </Section>

  <!-- EXPERIENCE -->
  <Section id="experience" title="experience">
    <div class="space-y-6">

      <details name="experience" class="border border-border hover:border-neon group">
        <summary class="p-6 cursor-pointer list-none">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-2">
            <h3 class="text-light font-bold group-hover:text-neon">
              &gt; Programmer Analyst @ New College of Florida
            </h3>
            <span class="text-gray text-sm">06/2023 — present</span>
          </div>
          <div class="flex items-start justify-between">
            <p class="text-gray text-sm">
              Building and upgrading web-based applications, working across
              front-end and back-end, and automating departmental processes.
            </p>
            <span class="text-gray group-open:text-neon text-sm ml-4 shrink-0">[+]</span>
          </div>
        </summary>
        <ul class="px-6 pb-6 space-y-2 text-gray text-sm">
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Developed and upgraded web-based applications, including the Student
            Evaluation System and Faculty Annual Activity Report, enhancing user functionality.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Worked on front-end and back-end tasks using PHP, JavaScript, PL/SQL, Python, HTML, CSS.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Consulted with users to gather requirements, prototype solutions, and conduct tests
            to ensure applications met their needs.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Automated recurring activities using PL/SQL and Applications Manager (UC4),
            streamlining departmental processes.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Participated in database design and adhered to industry best practices
            for system standards and documentation.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Wrote and maintained technical documentation, system diagrams, and procedural
            guides for both developers and users.
          </li>
        </ul>
      </details>

      <details name="experience" class="border border-border hover:border-neon group">
        <summary class="p-6 cursor-pointer list-none">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-2">
            <h3 class="text-light font-bold group-hover:text-neon">
              &gt; FTC Robotics Programming Mentor @ FUNducation
            </h3>
            <span class="text-gray text-sm">09/2024 — 02/2025</span>
          </div>
          <div class="flex items-start justify-between">
            <p class="text-gray text-sm">
              Led the software development team and mentored students in
              programming, debugging, and competition strategy for FTC robotics.
            </p>
            <span class="text-gray group-open:text-neon text-sm ml-4 shrink-0">[+]</span>
          </div>
        </summary>
        <ul class="px-6 pb-6 space-y-2 text-gray text-sm">
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Led the software development team across all stages of the development
            lifecycle, including coding, testing, and implementation.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Led the team in writing and debugging Java code using the FTC SDK to
            control the robot's motors, sensors, and actuators in both tele-operated
            and autonomous modes.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Provided hands-on instruction in coding practices, logic implementation,
            and robot design, ensuring alignment with competition rules.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Assisted students in troubleshooting and improving their code to optimize
            robot performance, including integration of the Control Hub and Expansion Hub.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Participated in strategic planning sessions to analyze competition challenges
            and develop effective autonomous programs.
          </li>
        </ul>
      </details>

      <details name="experience" class="border border-border hover:border-neon group">
        <summary class="p-6 cursor-pointer list-none">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-2">
            <h3 class="text-light font-bold group-hover:text-neon">
              &gt; Junior Software Developer @ AtLarge
            </h3>
            <span class="text-gray text-sm">11/2022 — 06/2023</span>
          </div>
          <div class="flex items-start justify-between">
            <p class="text-gray text-sm">
              Supported the full development lifecycle using Python, TypeScript,
              React, and PHP, collaborating with senior engineers on debugging
              and project planning.
            </p>
            <span class="text-gray group-open:text-neon text-sm ml-4 shrink-0">[+]</span>
          </div>
        </summary>
        <ul class="px-6 pb-6 space-y-2 text-gray text-sm">
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Supported the software development team across all stages of the
            development lifecycle, including coding, testing, and implementation.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Worked on front-end and back-end tasks using Python, TypeScript,
            JavaScript, HTML, CSS, React, PHP.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Collaborated with senior engineers in identifying solutions, debugging
            code, and attending developer meetings to discuss project progress.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Participated in code reviews and quality assurance processes to ensure
            adherence to coding standards.
          </li>
          <li class="border-l-2 border-border pl-3 hover:border-neon hover:text-light">
            Documented project progress and enhanced coding skills through
            continuous learning and collaboration.
          </li>
        </ul>
      </details>

    </div>
  </Section>

  <!-- CONTACT -->
  <Section id="contact" title="contact">
    <div class="max-w-xl">
      <p class="text-gray mb-6">
        &gt; Want to work together?
        <br />
        &gt; Reach me through any of these channels:
      </p>
      <div class="space-y-2 text-sm">
        <div class="border border-border p-3 hover:border-neon">
          <a href="mailto:e.snchez.c@gmail.com" class="text-neon hover:bg-neon hover:text-dark px-1">
            email
          </a>
          <span class="text-gray"> — e.snchez.c@gmail.com</span>
        </div>
        <div class="border border-border p-3 hover:border-neon">
          <a href="https://github.com/estefysc" target="_blank" rel="noopener noreferrer" class="text-neon hover:bg-neon hover:text-dark px-1">
            github
          </a>
          <span class="text-gray"> — github.com/estefysc</span>
        </div>
        <div class="border border-border p-3 hover:border-neon">
          <a href="https://www.linkedin.com/in/estefania-sanchez-172911228/" target="_blank" rel="noopener noreferrer" class="text-neon hover:bg-neon hover:text-dark px-1">
            linkedin
          </a>
          <span class="text-gray"> — linkedin.com/in/estefania-sanchez</span>
        </div>
      </div>
    </div>
  </Section>
</Layout>

<script>
  // Typing effect for the hero intro line.
  // Types out "hello, i'm" one character at a time, then reveals
  // the rest of the hero content.

  const text = "hello, i'm";
  const target = document.getElementById("typed-intro");
  const cursor = document.getElementById("typed-cursor");
  const heroContent = document.getElementById("hero-content");

  let i = 0;

  function typeChar() {
    if (!target) return;

    if (i < text.length) {
      // Append one character at a time
      target.textContent += text[i];
      i++;
      // Random delay between 40-120ms makes it feel like real human typing
      // (constant speed looks robotic)
      const delay = Math.random() * 80 + 40;
      setTimeout(typeChar, delay);
    } else {
      // Typing done — hide the intro cursor and reveal the rest
      cursor?.classList.add("hidden");
      heroContent?.classList.remove("hidden");
    }
  }

  // Start typing after a short pause (lets the page settle visually)
  setTimeout(typeChar, 500);
</script>
