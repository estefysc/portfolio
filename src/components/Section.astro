---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section id={id} class="border-b border-border px-6 py-16">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-neon text-2xl font-bold mb-8 uppercase tracking-wider">
      // {title}
    </h2>
    <slot />
  </div>
</section>
