---
const links = [
  { label: "about", href: "#about" },
  { label: "projects", href: "#projects" },
  { label: "experience", href: "#experience" },
  { label: "contact", href: "#contact" },
];
---

<nav class="sticky top-0 z-50 bg-dark border-b border-border px-6 py-4">
  <div class="max-w-5xl mx-auto flex items-center justify-between">
    <a href="/" class="text-neon font-bold hover:bg-neon hover:text-dark px-2 py-1">
      &gt;_ portfolio
    </a>

    <!-- Desktop links: hidden on mobile, visible from md breakpoint up -->
    <ul class="hidden md:flex gap-1">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-light hover:bg-neon hover:text-dark px-3 py-1 text-sm uppercase tracking-wider"
          >
            [{link.label}]
          </a>
        </li>
      ))}
    </ul>

    <!-- Hamburger button: visible on mobile, hidden from md up -->
    <button
      id="menu-toggle"
      class="md:hidden text-neon text-xl px-2 py-1 border border-border hover:bg-neon hover:text-dark"
      aria-label="Toggle menu"
    >
      ☰
    </button>
  </div>

  <!-- Mobile dropdown menu: hidden by default -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border mt-4 pt-4"
  >
    <ul class="flex flex-col gap-2">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link block text-light hover:bg-neon hover:text-dark px-3 py-2 text-sm uppercase tracking-wider"
          >
            &gt; {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  // This <script> runs in the browser — it's the only JS we ship.
  // It toggles the mobile menu visibility when the hamburger is clicked.
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    // .hidden is Tailwind's "display: none" class.
    // We toggle it on/off to show/hide the menu.
    menu?.classList.toggle("hidden");
  });

  // Close the menu when a link is clicked (so it doesn't stay open
  // after navigating to a section)
  const mobileLinks = document.querySelectorAll(".mobile-link");
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
    });
  });
</script>
