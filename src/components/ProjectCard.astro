---
interface Props {
  title: string;
  description: string;
  tech: string[];
  link?: string;
  github?: string;
}

const { title, description, tech, link, github } = Astro.props;
---

<div class="border border-border p-6 hover:border-neon transition-colors duration-0 group">
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-light font-bold text-lg group-hover:text-neon">
      &gt; {title}
    </h3>
    <div class="flex gap-3 text-sm">
      {link && (
        <a href={link} target="_blank" rel="noopener noreferrer" class="text-gray hover:bg-neon hover:text-dark px-1">
          [live]
        </a>
      )}
      {github && (
        <a href={github} target="_blank" rel="noopener noreferrer" class="text-gray hover:bg-neon hover:text-dark px-1">
          [src]
        </a>
      )}
    </div>
  </div>
  <p class="text-gray text-sm mb-4">{description}</p>
  <div class="flex flex-wrap gap-2">
    {tech.map((t) => (
      <span class="border border-border text-neon text-xs px-2 py-1 uppercase">
        {t}
      </span>
    ))}
  </div>
</div>
